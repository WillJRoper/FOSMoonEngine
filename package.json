{
  "name": "moon-engine",
  "private": true,
  "version": "0.1.0",
  "description": "A web app for displaying and interacting with simulation videos spread across a parameter hypercube.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode localmanifest",
    "local": "python3 scripts/run_local.py",
    "local_galaxy": "python3 scripts/run_local.py --mode galaxy",
    "local_cosmos": "python3 scripts/run_local.py --mode cosmos",
    "local_planet": "python3 scripts/run_local.py --mode planet",
    "build": "tsc && vite build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "preview": "vite preview",
    "generate:run-manifest": "python3 scripts/generate_run_manifest.py --local",
    "generate:hex-positions": "python3 scripts/generate_hex_positions.py",
    "download:assets": "python3 scripts/download_engine_assets.py",
    "download:cosmos": "python3 scripts/download_engine_assets.py --simulation cosmos",
    "setup:local": "python3 scripts/download_engine_assets.py && python3 scripts/generate_run_manifest.py --local",
    "tracking:server": "python3 scripts/local_tracking_server.py",
    "tracking:sync": "python3 scripts/sync_tracking_to_d1.py",
    "generate:scrub-proxies": "python3 scripts/generate_scrub_proxies.py public/assets",
    "format": "prettier --write \"src/**/*.{ts,css,yaml,yml}\" \"*.{md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css,yaml,yml}\" \"*.{md,json}\""
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.1",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
